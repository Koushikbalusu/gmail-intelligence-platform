# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_secret

# Google OAuth / Gmail API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Default chat model
DEFAULT_CHAT_MODEL=gemini-2.5-flash

# Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_nim_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Exposed selector options
NIM_MODEL_FAST=mistralai/mistral-nemotron
NIM_MODEL_SMART=nvidia/nemotron-3-ultra-550b-a55b
GEMINI_MODEL_FAST=gemini-2.5-flash

# Gmail sync
GMAIL_INITIAL_SYNC_LIMIT=200
GMAIL_PAGE_SIZE=50

# RAG / Retrieval
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.3
NEWS_DEDUP_THRESHOLD=0.85